# comind-mcp server — all optional in dev (sane fallbacks). Set real values in prod.

# HTTP
PORT=8787
HOST=127.0.0.1

# Postgres connection (matches docker-compose defaults)
DATABASE_URL=postgres://comind:comind@localhost:5432/comind

# Secrets vault key — 32 bytes, base64. Generate: openssl rand -base64 32
# The dev fallback is INSECURE; always override in production.
VAULT_KEY=

# HMAC secret for signing user session JWTs. The dev fallback is INSECURE.
JWT_SECRET=

# CORS: '*' in dev, or comma-separated origins
CORS_ORIGINS=*
